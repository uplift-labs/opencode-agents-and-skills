{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "provider": {
    "openai": {
      "options": {
        "setCacheKey": true
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "reserved": 10000
  },
  "tool_output": {
    "max_lines": 1000,
    "max_bytes": 24000
  },
  "mcp": {
    "headroom": {
      "type": "local",
      "command": [
        "node",
        "tools/headroom-mcp-wrapper.ts"
      ],
      "enabled": true,
      "environment": {
        "HEADROOM_TELEMETRY": "off",
        "HEADROOM_LOG_LEVEL": "WARN"
      },
      "timeout": 10000
    }
  },
  "lsp": true,
  "permission": "allow"
}
